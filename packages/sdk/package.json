{
  "name": "@traseq/sdk",
  "version": "0.3.1",
  "type": "module",
  "description": "Low-level Traseq API client, types, and signalGraph schema validation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/traseq/agent.git",
    "directory": "packages/sdk"
  },
  "sideEffects": false,
  "keywords": [
    "trading",
    "backtesting",
    "traseq",
    "sdk"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test ./test/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
